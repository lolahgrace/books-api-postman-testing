    {
      "name": "List of Books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "// ✅ Verify response status code",
              "pm.test('Status is 200 OK', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ✅ Validate response time",
              "pm.test('Response time is under 2000ms', () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// ✅ Validate response body structure",
              "pm.test('Response is an array', () => {",
              "    pm.expect(response).to.be.an('array');",
              "});",
              "",
              "pm.test('Books list is not empty', () => {",
              "    pm.expect(response.length).to.be.above(0);",
              "});",
              "",
              "pm.test('Each book has required fields', () => {",
              "    response.forEach((book) => {",
              "        pm.expect(book).to.have.property('id');",
              "        pm.expect(book).to.have.property('name');",
              "        pm.expect(book).to.have.property('type');",
              "        pm.expect(book).to.have.property('available');",
              "    });",
              "});",
              "",
              "pm.test('Book type is fiction or non-fiction', () => {",
              "    response.forEach((book) => {",
              "        pm.expect(book.type).to.be.oneOf(['fiction', 'non-fiction']);",
              "    });",
              "});",
              "",
              "pm.test('At least one book is available', () => {",
              "    const available = response.filter(book => book.available === true);",
              "    pm.expect(available.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
