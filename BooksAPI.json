    {
      "name": "Create Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomEmail = 'lolatest' + Date.now() + '@gmail.com';",
              "pm.environment.set('clientEmail', randomEmail);",
              "console.log('Generated email: ' + randomEmail);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "// ✅ Verify response status code",
              "pm.test('Status is 201 Created', () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// ✅ Validate response time",
              "pm.test('Response time is under 2000ms', () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// ✅ Validate response body structure",
              "pm.test('Response contains accessToken field', () => {",
              "    pm.expect(response).to.have.property('accessToken');",
              "});",
              "",
              "pm.test('Access token is a non-empty string', () => {",
              "    pm.expect(response.accessToken).to.be.a('string');",
              "    pm.expect(response.accessToken).to.not.be.empty;",
              "});",
              "",
              "// Save token for subsequent requests",
              "if (pm.response.code === 201) {",
              "    pm.environment.set('access_token', response.accessToken);",
              "    console.log('Token saved: ' + response.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {"type": "noauth"},
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
